      "isEnding": false,
      "decisions": [
        {
          "text": "Mergi la atelierul mecanicului",
          "targetBlockId": "workshop.entry",
          "effects": [
            {
              "type": "add",
              "property": "player.energy",
              "value": -5
            }
          ]
        },
        {
          "text": "Intra in piata clandestina",
          "targetBlockId": "market.trader",
          "effects": [
            {
              "type": "add",
              "property": "story.suspicion",
              "value": 10
            }
          ]
        },
        {
          "text": "Ia scurtatura prin aleea ingusta",
          "targetBlockId": "alley.shortcut",
          "effects": [
            {
              "type": "add",
              "property": "player.energy",
              "value": -10
            },
            {
              "type": "add",
              "property": "story.suspicion",
              "value": 15
            }
          ]
        }
      ]
    },
    {
